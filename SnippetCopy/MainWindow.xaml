<Window x:Class="SnippetCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnippetCopy"
        mc:Ignorable="d"
        Title="SnippetCopy" Height="600" Width="900"
        Background="#1E1E1E" Foreground="WhiteSmoke">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width = "220"/>
            <ColumnDefinition Width = "*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Side -->
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Categories" FontSize="12" Margin="0,0,0,3"/>
            <ComboBox x:Name="filterCategory" SelectionChanged="Filter_Changed"/>
            
            <TextBox x:Name="searchBox" TextChanged="Search_Changed" Margin="0,0,0,8" Padding="5,3"/>
            
            <ListBox x:Name="snippetList" DisplayMemberPath="Name" 
                     SelectionChanged="SnippetList_SelectionChanged"
                     Height="240" Margin="0,0,0,10"
                     Background="#2D2D2D" Foreground="WhiteSmoke"/>
            
            <Button Content="Copy" Click="Copy_Click" Height="42" Margin="0,0,0,4"
                    Background="#0078D4" Foreground="White" BorderThickness="0"/>
            <Button Content="New" Click="New_Click" Height="32" Margin="0,0,0,4"
                    Background="#333" Foreground="White" BorderThickness="0"/>
            <Button Content="Edit" Click="Edit_Click" Height="32" Margin="0,0,0,4"
                    Background="#333" Foreground="White" BorderThickness="0"/>
            <Button Content="Delete" Click="Delete_Click" Height="32"
                    Background="#8B0000" Foreground="White" BorderThickness="0"/>
        </StackPanel>
        
        <!-- Right Side: Preview -->
        <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="5" Padding="15"
                BorderBrush="#444" BorderThickness="1">
            <TextBlock x:Name="Preview" Text="Select a snippet..." 
                       FontSize="14" TextWrapping="Wrap"
                       Foreground="#CCC"/>
        </Border>
        
        <!-- Right Side: Edit/New Panel -->
        <Border Grid.Column="1" x:Name="newPanel" Visibility="Collapsed"
                Background="#2D2D2D" CornerRadius="5" Padding="15"
                BorderBrush="#444" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Name" FontSize="12" Margin="0,0,0,3"/>
                <TextBox x:Name="newName" Margin="0,0,0,10" Padding="5,3"/>

                <TextBlock Text="Content" FontSize="12" Margin="0,0,0,3"/>
                <TextBox AcceptsReturn="True" x:Name="newContent" Height="150" 
                         Margin="0,0,0,10" Padding="5,3"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="Category" FontSize="12" Margin="0,0,0,3"/>
                <ComboBox x:Name="newCategory" IsEditable="True" Margin="0,0,0,15"/>

                <Button Content="Save" Click="Save_Click" Height="35"
                        Background="#0078D4" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
