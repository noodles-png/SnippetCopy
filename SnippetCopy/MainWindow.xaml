<Window x:Class="SnippetCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnippetCopy"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width = "200"/>
            <ColumnDefinition Width = "*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0">
            <ListBox x:Name="snippetList" DisplayMemberPath="Name" SelectionChanged="SnippetList_SelectionChanged"/> 
            <Button Content="Copy Snippet" Click="Copy_Click" Height="35" Margin="0,5,0,5"/>
            <Button Content="New Snippet" Click="New_Click"/>
            <Button Content="Edit Snippet" />
            <Button Content="Delete Snippet" Click="Delete_Click" Background="DarkRed"/>
        </StackPanel>
        <TextBlock Grid.Column="1" x:Name="Preview" Text="Choose a Snippet"/>
        <StackPanel Grid.Column="1" x:Name="newPanel" Visibility="Collapsed">
            <TextBox x:Name="newName"/>
            <TextBox x:Name="newContent"/>
            <Button Content="Save" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
